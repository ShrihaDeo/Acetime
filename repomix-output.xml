}

.suit.red {
  color: #8b0000;
  opacity: 0.06;
}

.bg-cycle-btn {
  position: absolute;
  top: -20px;
  right: 30px;
  background-color: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.2);
  color: white;
  padding: 10px 20px;
  border-radius: 20px;
  font-size: 11px;
