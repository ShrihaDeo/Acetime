.suit:nth-child(1) { top: -40px; left: -40px; transform: rotate(-15deg); }
.suit:nth-child(2) { top: -40px; right: -40px; transform: rotate(15deg); }
.suit:nth-child(3) { bottom: -40px; left: -40px; transform: rotate(15deg); }
.suit:nth-child(4) { bottom: -40px; right: -40px; transform: rotate(-15deg); }

.table-suits {
  position: absolute;
  width: 100%;
